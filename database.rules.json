{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth != null && (root.child('roles').child(auth.uid).val() === 'owner' || root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'moderator')",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid && !root.child('bans').child($uid).exists()"
      }
    },

    "roles": {
      ".read": "auth != null && (root.child('roles').child(auth.uid).val() === 'owner' || root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'moderator')",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'owner' || (root.child('roles').child(auth.uid).val() === 'admin' && root.child('roles').child($uid).val() !== 'owner' && root.child('roles').child($uid).val() !== 'admin' && newData.val() !== 'owner' && newData.val() !== 'admin'))",
        ".validate": "!newData.exists() || (newData.isString() && (newData.val() === 'owner' || newData.val() === 'admin' || newData.val() === 'moderator' || newData.val() === 'user'))"
      }
    },

    "bans": {
      ".read": "auth != null && (root.child('roles').child(auth.uid).val() === 'owner' || root.child('roles').child(auth.uid).val() === 'admin')",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'owner' || (root.child('roles').child(auth.uid).val() === 'admin' && root.child('roles').child($uid).val() !== 'owner' && root.child('roles').child($uid).val() !== 'admin'))"
      }
    },

    "siteConfig": {
      ".read": true,
      ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'owner' || root.child('roles').child(auth.uid).val() === 'admin')"
    },

    "content": {
      ".read": true,
      ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'owner' || root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'moderator')"
    },

    "auditLog": {
      ".read": "auth != null && (root.child('roles').child(auth.uid).val() === 'owner' || root.child('roles').child(auth.uid).val() === 'admin')",
      "$id": {
        ".write": "auth != null && !data.exists() && (root.child('roles').child(auth.uid).val() === 'owner' || root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'moderator')"
      }
    }
  }
}
